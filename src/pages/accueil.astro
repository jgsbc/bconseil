---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.startsWith('/') ? path.slice(1) : path}`;
---

<BaseLayout title="Accueil">
  <Header />
  <main class="flex-grow">
    <Section class="bg-visual bg-inner-a bg-visual-readable premium-gradient min-h-[70vh] flex items-center border-b border-bc-border">
      <Container>
        <Eyebrow>Cabinet de Conseil Patrimonial</Eyebrow>
        <h1 class="max-w-4xl text-4xl md:text-6xl lg:text-7xl mb-8 leading-tight">
          Conseil patrimonial pour les décisions qui engagent l'avenir
        </h1>
        <p class="max-w-2xl text-xl text-bc-text-secondary mb-12">
          À Collonges-au-Mont-d'Or, Lyon et dans toute la région Rhône-Alpes, Aurélien Picard accompagne les décideurs et les familles avec une approche confidentielle, indépendante et inscrite dans la durée.
        </p>
        <div class="flex flex-wrap gap-6">
          <Button href={withBase('/expertises')} variant="primary">Découvrir nos expertises</Button>
          <Button href={withBase('/contact')} variant="outline">Prendre contact</Button>
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <Eyebrow>Situations accompagnées</Eyebrow>
        <h2 class="mb-12">Structurer, protéger et transmettre</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Préparer une retraite</h3>
            <p class="text-bc-text-secondary text-sm mb-0">Anticiper la fin d'activité, estimer les besoins futurs et mettre en place des revenus complémentaires réguliers et pérennes.</p>
          </Card>
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Protéger une famille</h3>
            <p class="text-bc-text-secondary text-sm mb-0">Sécuriser l'avenir de ses proches face aux aléas de la vie grâce à des solutions de prévoyance et des capitaux garantis.</p>
          </Card>
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Organiser une transmission</h3>
            <p class="text-bc-text-secondary text-sm mb-0">Préparer la transmission de son patrimoine privé ou professionnel avec anticipation, en maîtrisant les impacts civils et fiscaux.</p>
          </Card>
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Accompagner un dirigeant</h3>
            <p class="text-bc-text-secondary text-sm mb-0">Protéger le dirigeant, anticiper la cession de l'entreprise et structurer la rémunération ainsi que la trésorerie d'entreprise.</p>
          </Card>
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Structurer le patrimoine</h3>
            <p class="text-bc-text-secondary text-sm mb-0">Articuler les dimensions privées et professionnelles, diversifier les actifs et mettre en cohérence l'ensemble des investissements.</p>
          </Card>
        </div>
      </Container>
    </Section>

    <Section bg="secondary" class="bg-visual bg-structured-a bg-visual-soft border-y border-bc-border">
      <Container>
        <Eyebrow>Notre approche</Eyebrow>
        <h2 class="mb-12">Une méthode structurée</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="space-y-4">
            <h3 class="text-bc-accent-champagne text-xl font-serif">1. Comprendre</h3>
            <p class="text-bc-text-secondary text-sm">Une écoute attentive pour saisir l'ensemble de vos enjeux personnels et professionnels, sans solution préconçue.</p>
          </div>
          <div class="space-y-4">
            <h3 class="text-bc-accent-champagne text-xl font-serif">2. Structurer</h3>
            <p class="text-bc-text-secondary text-sm">L'élaboration d'une stratégie sur-mesure, indépendante et parfaitement adaptée à vos objectifs et à votre situation.</p>
          </div>
          <div class="space-y-4">
            <h3 class="text-bc-accent-champagne text-xl font-serif">3. Accompagner dans la durée</h3>
            <p class="text-bc-text-secondary text-sm">Un suivi régulier qui s'ajuste au fil du temps pour faire évoluer votre patrimoine à chaque étape de votre vie.</p>
          </div>
        </div>
      </Container>
    </Section>

    <Section>
      <Container class="max-w-3xl text-center">
        <Eyebrow>Engagement</Eyebrow>
        <h2 class="mb-6">Un cadre professionnel vérifiable</h2>
        <p class="text-bc-text-secondary mb-8">
          L'activité de Berlioz Conseil s'exerce dans un cadre strictement réglementé, garantissant sérieux, confidentialité et transparence dans l'accompagnement de vos projets.
        </p>
        <div class="bg-bc-surface border border-bc-border p-8 text-left inline-block w-full text-sm space-y-4">
          <p><strong>Numéro ORIAS :</strong> 19004281</p>
          <p><strong>Catégories d'enregistrement :</strong> Conseiller en Investissements Financiers (CIF), Courtier en Assurance (COA), Courtier et Mandataire en Opérations de Banque et en Services de Paiement (COBSP / MOBSP).</p>
          <p class="italic text-bc-text-muted mb-0">Le cabinet ne peut recevoir aucun fonds, effet ou valeur autre que ceux destinés à la rémunération de ses prestations.</p>
        </div>
      </Container>
    </Section>

    <CTASection />
  </main>
  <Footer />
</BaseLayout>
