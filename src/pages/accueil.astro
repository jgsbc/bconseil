---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="Accueil">
  <Header />
  <main class="flex-grow">
    <Section class="premium-gradient min-h-[70vh] flex items-center border-b border-bc-border">
      <Container>
        <Eyebrow>Cabinet de Conseil Patrimonial</Eyebrow>
        <h1 class="max-w-4xl text-5xl md:text-7xl mb-8">
          Gestion de patrimoine <span class="text-bc-accent-champagne italic">indépendante</span> [À VALIDER]
        </h1>
        <p class="max-w-2xl text-xl text-bc-text-secondary mb-12">
          À Collonges-au-Mont-d'Or et dans toute la région Rhône-Alpes, Aurélien Picard vous accompagne sur vos enjeux de retraite, prévoyance, transmission et protection du dirigeant. [À VALIDER]
        </p>
        <div class="flex flex-wrap gap-6">
          <Button href="/expertises" variant="primary">Découvrir nos expertises</Button>
          <Button href="/contact" variant="outline">Prendre contact</Button>
        </div>
      </Container>
    </Section>

    <Section bg="secondary">
      <Container>
        <Eyebrow>Notre approche</Eyebrow>
        <h2 class="mb-12">Une méthode structurée [À VALIDER]</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">1. Analyse globale</h3>
            <p class="text-bc-text-secondary text-sm">Comprendre l'ensemble de vos enjeux personnels et professionnels. [À VALIDER]</p>
          </Card>
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">2. Stratégie sur-mesure</h3>
            <p class="text-bc-text-secondary text-sm">Élaborer des solutions indépendantes et adaptées à votre situation. [À VALIDER]</p>
          </Card>
          <Card>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">3. Suivi dans la durée</h3>
            <p class="text-bc-text-secondary text-sm">Un accompagnement régulier qui évolue avec votre patrimoine. [À VALIDER]</p>
          </Card>
        </div>
      </Container>
    </Section>

    <Section>
      <Container class="max-w-3xl text-center">
        <Eyebrow>À qui s'adresse le cabinet ?</Eyebrow>
        <h2 class="mb-6">Pour les décideurs et les familles [À VALIDER]</h2>
        <p class="text-bc-text-secondary mb-8">
          Dirigeants d'entreprise, entrepreneurs, professions libérales et familles : Berlioz Conseil s'adresse aux personnes recherchant un accompagnement structuré, confidentiel et inscrit dans la durée. [À VALIDER]
        </p>
      </Container>
    </Section>

    <CTASection />
  </main>
  <Footer />
</BaseLayout>
