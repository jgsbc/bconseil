---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Accueil" description="Conseil patrimonial confidentiel en Rhône-Alpes. Assurance, investissement, prévoyance et transmission : un accompagnement structuré pour les décisions qui engagent l'avenir.">
  <main class="min-h-screen flex items-center justify-center premium-gradient relative overflow-hidden px-6">
    <!-- Abstract background effect -->
    <div class="absolute inset-0 pointer-events-none ambient-halo" style="background: radial-gradient(circle at 50% 50%, var(--color-bc-accent-bronze) 0%, transparent 60%);"></div>
    
    <div class="relative z-10 max-w-2xl text-center flex flex-col items-center">
      <!-- Logo placeholder -->
      <div class="mb-12 entrance-up">
        <h1 class="text-3xl md:text-5xl font-light tracking-widest uppercase text-bc-text-primary font-serif">
          Berlioz <span class="text-bc-accent-bronze block mt-2 text-2xl md:text-4xl">Conseil</span>
        </h1>
      </div>

      <p class="text-bc-text-secondary text-lg md:text-xl mb-12 max-w-xl mx-auto leading-relaxed entrance-up entrance-delay-1">
        Conseil patrimonial confidentiel en Rhône-Alpes. Assurance, investissement, prévoyance et transmission : un accompagnement structuré pour les décisions qui engagent l'avenir. <span class="text-xs ml-1 opacity-50">[À VALIDER]</span>
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center w-full max-w-md entrance-up entrance-delay-2">
        <Button href="/accueil" variant="primary" class="w-full">
          Découvrir
        </Button>
        <Button href="/acces-client" variant="outline" class="w-full">
          Initié
        </Button>
      </div>
    </div>
  </main>
</BaseLayout>
