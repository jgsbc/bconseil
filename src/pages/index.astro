---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Accueil">
	<Header />
	<main class="flex-grow py-24">
		<div class="container">
			<span class="text-zinc-500 uppercase tracking-[0.3em] text-xs mb-4 block">Cabinet de Conseil Patrimonial</span>
			<h1>Berlioz Conseil — accompagnement patrimonial confidentiel [À VALIDER]</h1>
			<p class="max-w-2xl">
				Une approche sélective et exigeante pour la protection et la transmission de votre patrimoine. 
				Placeholder de présentation à valider par Berlioz Conseil.
			</p>
		</div>
	</main>
	<Footer />
</BaseLayout>
