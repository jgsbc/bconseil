---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const withBase = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
---

<BaseLayout title="Demande envoyée">
  <Header />
  <main class="flex-grow premium-gradient flex flex-col justify-center min-h-[60vh]">
    <Section class="text-center">
      <Container class="max-w-2xl">
        <h1 class="mb-6 font-serif">Merci pour votre message</h1>
        <p class="mb-12 text-bc-text-secondary text-lg">Votre demande a bien été transmise à Berlioz Conseil.</p>
        
        <Card class="inline-block p-12 max-w-xl mx-auto">
          <p class="text-bc-text-secondary mb-8">
            Nous avons bien reçu votre demande de contact et nous vous répondrons dans les meilleurs délais selon votre préférence de communication.
          </p>
          <div class="pt-4">
            <Button href={withBase('/')} variant="primary">
              Retour à l'accueil
            </Button>
          </div>
        </Card>
      </Container>
    </Section>
  </main>
  <Footer />
</BaseLayout>
