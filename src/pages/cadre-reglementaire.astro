---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import LegalNoticeBlock from '../components/LegalNoticeBlock.astro';
---

<BaseLayout title="Cadre réglementaire">
  <Header />
  <main class="flex-grow">
    <PageHero 
      title="Cadre réglementaire" 
      description="Berlioz Conseil exerce une activité réglementée. Contenu à valider par le cabinet." 
    />
    
    <Section>
      <Container class="max-w-3xl">
        <div class="space-y-6">
          <LegalNoticeBlock title="ORIAS">
            <p>Immatriculation : 19004281 [À VALIDER]</p>
          </LegalNoticeBlock>
          
          <LegalNoticeBlock title="Association professionnelle">
            <p>Membre de la CNCGP [À VALIDER]</p>
          </LegalNoticeBlock>

          <LegalNoticeBlock title="Autorités de contrôle">
            <p>ACPR, AMF [À VALIDER]</p>
          </LegalNoticeBlock>

          <LegalNoticeBlock title="Médiateur">
            <p>[À FOURNIR]</p>
          </LegalNoticeBlock>
        </div>
      </Container>
    </Section>
  </main>
  <Footer />
</BaseLayout>
