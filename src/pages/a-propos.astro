---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="À propos">
	<Header />
	<main class="flex-grow py-24">
		<div class="container">
			<h1>À propos de Berlioz Conseil</h1>
			<p>Parcours, certifications et posture d'Aurélien Picard. Contenu à fournir.</p>
			<div class="mt-12 max-w-3xl">
				<p class="italic">[Texte de présentation validé à fournir]</p>
			</div>
		</div>
	</main>
	<Footer />
</BaseLayout>
