---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="À propos">
  <Header />
  <main class="flex-grow">
    <PageHero 
      title="À propos de Berlioz Conseil" 
      description="Parcours, posture et certifications." 
    />
    
    <Section>
      <Container class="max-w-3xl">
        <div class="max-w-none text-bc-text-secondary space-y-8">
          <p class="text-xl text-bc-text-primary font-light italic border-l-2 border-bc-accent-champagne pl-6 py-2 mb-12">
            "Berlioz Conseil accompagne les décisions patrimoniales importantes avec méthode, discrétion et exigence." [À VALIDER]
          </p>
          
          <div>
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Aurélien Picard</h3>
            <p class="mb-4">
              Fort d'une expérience de plus de 15 ans dans le secteur financier et patrimonial, Aurélien Picard a fondé Berlioz Conseil avec la volonté d'offrir un accompagnement indépendant et structuré. [À VALIDER]
            </p>
            <ul class="space-y-3 text-bc-text-secondary mt-6 border-l border-bc-border pl-6">
              <li><strong class="text-bc-text-primary font-medium">Depuis 2019 :</strong> Berlioz Conseil — Conseiller en investissement financier indépendant.</li>
              <li><strong class="text-bc-text-primary font-medium">2013-2019 :</strong> Allianz — Conseiller en gestion de patrimoine.</li>
              <li><strong class="text-bc-text-primary font-medium">2009-2012 :</strong> GAN — Conseil en patrimoine et prévoyance.</li>
              <li><strong class="text-bc-text-primary font-medium">2008 :</strong> CIC — Conseiller en gestion de patrimoine (stage de fin d'étude).</li>
            </ul>
          </div>

          <div class="pt-8 border-t border-bc-border">
            <h3 class="text-bc-text-primary text-xl font-serif mb-6">Formations</h3>
            <ul class="space-y-4 text-bc-text-secondary">
              <li>
                <strong class="text-bc-text-primary block">iaelyon School of Management</strong>
                Master 2 Finance et services de gestion financière.
              </li>
              <li>
                <strong class="text-bc-text-primary block">JurisCampus</strong>
                AMF Finance Durable, niveau réussite [À VALIDER].
              </li>
              <li>
                <strong class="text-bc-text-primary block">IDRAC Business School</strong>
                Master 1 marketing et management européen, spécialité finance.
              </li>
              <li>
                <strong class="text-bc-text-primary block">University of Huddersfield</strong>
                BA International Business.
              </li>
            </ul>
          </div>

          <div class="pt-8 border-t border-bc-border">
            <h3 class="text-bc-text-primary text-xl font-serif mb-4">Références</h3>
            <p class="mb-4 text-bc-text-muted italic">
              [À FOURNIR] Références affichables si applicable.
            </p>
          </div>
        </div>
      </Container>
    </Section>

    <CTASection />
  </main>
  <Footer />
</BaseLayout>
