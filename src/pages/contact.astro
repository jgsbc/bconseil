---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import LegalNoticeBlock from '../components/LegalNoticeBlock.astro';
---

<BaseLayout title="Contact">
  <Header />
  <main class="flex-grow">
    <PageHero 
      title="Prendre Contact" 
      description="Pour toute demande d'accompagnement patrimonial, merci d'utiliser les coordonnées ci-dessous." 
    />
    
    <Section>
      <Container class="max-w-3xl">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16">
          <LegalNoticeBlock title="Coordonnées">
            <p>Email : contact@berliozconseil.fr [À VALIDER]</p>
            <p>Téléphone : [À FOURNIR]</p>
          </LegalNoticeBlock>
          <LegalNoticeBlock title="Adresse">
            <p>6 rue de la Pelonnière<br/>69660 Collonges-au-Mont-d'Or</p>
          </LegalNoticeBlock>
        </div>

        <div class="border border-bc-border bg-bc-bg-secondary p-8 text-center">
          <p class="text-bc-text-muted text-sm italic mb-0">
            Note : Le formulaire de contact qualifié sera implémenté lors du Lot 4. 
            Conformément au cadrage, il ne collectera aucune donnée patrimoniale détaillée.
          </p>
        </div>

      </Container>
    </Section>
  </main>
  <Footer />
</BaseLayout>
