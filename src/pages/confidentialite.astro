---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Confidentialité">
	<Header />
	<main class="flex-grow py-24">
		<div class="container">
			<h1>Politique de confidentialité</h1>
			<p>Contenu RGPD à fournir et valider.</p>
			<div class="mt-8 text-zinc-400">
				<p>Le site ne collecte aucune donnée patrimoniale détaillée.</p>
			</div>
		</div>
	</main>
	<Footer />
</BaseLayout>
