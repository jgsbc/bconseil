---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import LegalNoticeBlock from '../components/LegalNoticeBlock.astro';
---

<BaseLayout title="Mentions légales">
  <Header />
  <main class="flex-grow">
    <PageHero 
      title="Mentions légales" 
      description="Informations légales et obligatoires." 
      bgClass="bg-visual bg-legal-b bg-visual-legal"
    />
    
    <Section>
      <Container class="max-w-3xl">
        <div class="space-y-8">
          <LegalNoticeBlock title="Éditeur du site">
            <p>Dénomination : Berlioz Conseil</p>
            <p>Forme juridique : EURL</p>
            <p>SIRET : 85068322800025</p>
            <p>Adresse : 6 rue de la Pelonnière, 69660 Collonges-au-Mont-d'Or</p>
            <p>Dirigeant : Aurélien Picard</p>
            <p>Email : contact@berliozconseil.fr</p>
            <p>Téléphone : +33603071011</p>
          </LegalNoticeBlock>

          <LegalNoticeBlock title="Direction de la publication">
            <p>Directeur de la publication : Aurélien Picard</p>
          </LegalNoticeBlock>

          <LegalNoticeBlock title="Activité réglementée">
            <p>ORIAS : 19004281 [À VALIDER - attestation et liste des statuts exacts]</p>
            <p>Association professionnelle : Membre de la CNCGP [À VALIDER - numéro d'adhérent à fournir]</p>
