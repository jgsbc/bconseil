---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import ExpertiseCard from '../components/ExpertiseCard.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="Nos Expertises">
  <Header />
  <main class="flex-grow">
    <PageHero 
      title="Nos Expertises" 
      description="Domaines d'accompagnement patrimonial et stratégique. " 
      bgClass="bg-visual bg-structured-a bg-visual-readable"
    />
    
    <Section>
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          
          <!-- 1. Protéger -->
          <div class="bg-bc-bg-primary border border-bc-border p-8 hover:border-bc-accent-champagne transition-colors duration-300">
            <h3 class="text-bc-accent-champagne text-2xl font-serif mb-6">Protéger</h3>
            <ul class="space-y-3 text-bc-text-secondary">
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Protection de la famille et du conjoint</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Maintien des revenus</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Prévoyance</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Assurances</li>
            </ul>
          </div>

          <!-- 2. Préparer -->
          <div class="bg-bc-bg-primary border border-bc-border p-8 hover:border-bc-accent-champagne transition-colors duration-300">
            <h3 class="text-bc-accent-champagne text-2xl font-serif mb-6">Préparer</h3>
            <ul class="space-y-3 text-bc-text-secondary">
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Anticipation de la retraite</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Arbitrages patrimoniaux</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Organisation progressive du patrimoine</li>
            </ul>
          </div>

          <!-- 3. Transmettre -->
          <div class="bg-bc-bg-primary border border-bc-border p-8 hover:border-bc-accent-champagne transition-colors duration-300">
            <h3 class="text-bc-accent-champagne text-2xl font-serif mb-6">Transmettre</h3>
            <ul class="space-y-3 text-bc-text-secondary">
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Transmission du patrimoine</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Transmission d'entreprise</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Droit successoral</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Régimes matrimoniaux</li>
            </ul>
          </div>

          <!-- 4. Structurer -->
          <div class="bg-bc-bg-primary border border-bc-border p-8 hover:border-bc-accent-champagne transition-colors duration-300">
            <h3 class="text-bc-accent-champagne text-2xl font-serif mb-6">Structurer</h3>
            <ul class="space-y-3 text-bc-text-secondary">
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Patrimoine privé et professionnel</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Allocation et gestion d'actifs</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Analyse financière et économie</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Conseil fiscal</li>
            </ul>
          </div>

          <!-- 5. Accompagner le dirigeant -->
          <div class="bg-bc-bg-primary border border-bc-border p-8 hover:border-bc-accent-champagne transition-colors duration-300 lg:col-span-2">
            <h3 class="text-bc-accent-champagne text-2xl font-serif mb-6">Accompagner le dirigeant</h3>
            <ul class="space-y-3 text-bc-text-secondary grid grid-cols-1 md:grid-cols-2 gap-y-3 gap-x-8">
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Protection du dirigeant</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Articulation patrimoine professionnel / personnel</li>
              <li class="flex items-start gap-3"><span class="text-bc-accent-bronze mt-1">▪</span> Cession et transmission d'entreprise</li>
            </ul>
          </div>

        </div>
      </Container>
    </Section>

    <CTASection />
  </main>
  <Footer />
</BaseLayout>
