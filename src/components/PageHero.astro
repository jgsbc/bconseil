---
import Container from './Container.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---
<header class="py-24 md:py-32 border-b border-bc-border premium-gradient">
  <Container>
    <h1 class="mb-4 md:mb-6">{title}</h1>
    {description && <p class="max-w-2xl text-xl text-bc-text-secondary m-0">{description}</p>}
  </Container>
</header>
