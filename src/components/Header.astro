---
const navItems = [
  { name: 'Expertises', href: '/expertises' },
  { name: 'À propos', href: '/a-propos' },
  { name: 'Cadre réglementaire', href: '/cadre-reglementaire' },
  { name: 'Accès client', href: '/acces-client' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="border-b border-bc-border py-6 sticky top-0 bg-bc-bg-primary/80 backdrop-blur-md z-50">
  <div class="w-full max-w-6xl mx-auto px-6 flex justify-between items-center">
    <a href="/" class="text-xl font-light tracking-widest uppercase text-bc-text-primary font-serif hover:text-bc-accent-champagne transition-colors">
      Berlioz <span class="text-bc-accent-bronze">Conseil</span>
    </a>
    
    <nav class="hidden md:flex gap-8">
      {navItems.map(item => (
        <a href={item.href} class="text-sm uppercase tracking-widest text-bc-text-muted hover:text-bc-accent-champagne transition-colors">
          {item.name}
        </a>
      ))}
    </nav>
    
    <button class="md:hidden text-bc-text-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
</header>
