---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
  disabled?: boolean;
  [key: string]: any;
}

const { href, variant = 'primary', class: className = '', disabled = false, ...rest } = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-6 py-3 text-sm tracking-wider uppercase transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bc-accent-champagne focus-visible:ring-offset-2 focus-visible:ring-offset-bc-bg-primary";

const variants = {
  primary: "bg-bc-accent-champagne text-bc-bg-primary hover:bg-bc-text-primary hover:shadow-[0_0_20px_rgba(200,169,106,0.3)]",
  secondary: "bg-bc-surface text-bc-text-primary hover:bg-bc-bg-secondary border border-bc-border",
  outline: "bg-transparent text-bc-text-primary border border-bc-accent-champagne hover:bg-bc-accent-champagne hover:text-bc-bg-primary hover:shadow-[inset_0_0_15px_rgba(200,169,106,0.15)]"
};

const disabledStyles = disabled ? "opacity-50 cursor-not-allowed pointer-events-none" : "cursor-pointer";

const Element = href ? 'a' : 'button';
---
<Element 
  href={disabled ? undefined : href} 
  class={`${baseStyles} ${variants[variant]} ${disabledStyles} ${className}`}
  disabled={disabled}
  {...rest}
>
  <slot />
</Element>
