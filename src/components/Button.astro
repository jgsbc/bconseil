---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
  disabled?: boolean;
}

const { href, variant = 'primary', class: className = '', disabled = false } = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-6 py-3 text-sm tracking-wider uppercase transition-colors duration-300";

const variants = {
  primary: "bg-bc-accent-champagne text-bc-bg-primary hover:bg-bc-text-primary",
  secondary: "bg-bc-surface text-bc-text-primary hover:bg-bc-bg-secondary border border-bc-border",
  outline: "bg-transparent text-bc-text-primary border border-bc-accent-champagne hover:bg-bc-accent-champagne hover:text-bc-bg-primary"
};

const disabledStyles = disabled ? "opacity-50 cursor-not-allowed pointer-events-none" : "cursor-pointer";

const Element = href ? 'a' : 'button';
---
<Element 
  href={disabled ? undefined : href} 
  class={`${baseStyles} ${variants[variant]} ${disabledStyles} ${className}`}
  disabled={disabled}
>
  <slot />
</Element>
