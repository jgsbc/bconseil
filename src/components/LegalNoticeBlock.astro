---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<div class="border-l-2 border-bc-accent-bronze pl-6 py-2 my-8">
  <h3 class="text-bc-text-primary text-base font-medium mb-2 uppercase tracking-wide">{title}</h3>
  <div class="text-bc-text-muted text-sm space-y-2">
    <slot />
  </div>
</div>
