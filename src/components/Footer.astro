---
import Container from './Container.astro';

const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-bc-border py-16 bg-bc-bg-secondary">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div>
        <h3 class="text-bc-text-primary font-medium mb-6 uppercase tracking-widest text-xs">Berlioz Conseil</h3>
        <p class="text-sm text-bc-text-muted leading-relaxed">Conseil patrimonial, assurance et stratégie de protection [À VALIDER].</p>
      </div>
      <div>
        <h3 class="text-bc-text-primary font-medium mb-6 uppercase tracking-widest text-xs">Navigation</h3>
        <ul class="space-y-3 text-sm text-bc-text-muted">
          <li><a href="/expertises" class="hover:text-bc-accent-champagne transition-colors">Expertises</a></li>
          <li><a href="/a-propos" class="hover:text-bc-accent-champagne transition-colors">À propos</a></li>
          <li><a href="/cadre-reglementaire" class="hover:text-bc-accent-champagne transition-colors">Cadre réglementaire</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-bc-text-primary font-medium mb-6 uppercase tracking-widest text-xs">Légal</h3>
        <ul class="space-y-3 text-sm text-bc-text-muted">
          <li><a href="/mentions-legales" class="hover:text-bc-accent-champagne transition-colors">Mentions légales</a></li>
          <li><a href="/confidentialite" class="hover:text-bc-accent-champagne transition-colors">Confidentialité</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-bc-border pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-bc-text-muted uppercase tracking-widest">
      <p>&copy; {currentYear} Berlioz Conseil. Tous droits réservés.</p>
      <p>ORIAS : 19004281 [À VALIDER] | CNCGP [À VALIDER]</p>
    </div>
  </Container>
</footer>
